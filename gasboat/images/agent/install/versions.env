# versions.env — canonical version and package definitions for gasboat agent image.
#
# This file is the SINGLE SOURCE OF TRUTH for all tool versions and package
# lists in the agent image. Both the Dockerfile and .rwx/docker.yml source it.
#
# To add a tool: add it here, then add install logic to the appropriate script
# (clis.sh, go-tools.sh, etc.) — both build systems pick it up automatically.
#
# To update a version: change it here and bump the relevant .rwx/agent-*.lock
# cache-epoch to force an RWX rebuild.

# ── Runtimes ────────────────────────────────────────────────────────
export NODE_MAJOR=24
export GO_VERSION=1.25
export PYTHON_VERSION=3.12

# ── Tool versions ──────────────────────────────────────────────────
export DOCKER_VERSION=27.5.1
export DOCKER_COMPOSE_VERSION=2.35.1
export TERRAFORM_VERSION=1.11.3
export TERRAGRUNT_VERSION=0.77.11
export GOLANGCI_LINT_VERSION=1.64.8
export STERN_VERSION=1.30.0
export CLAUDELESS_VERSION=v0.4.0
export RTK_VERSION=0.23.0
export RWX_CLI_VERSION=3.7.1
export WHISPER_CPP_VERSION=1.8.3
export K6_VERSION=1.6.1
export PLAYWRIGHT_VERSION=1.58.2

# ── Base apt packages (minimal agent: git, Node.js, Claude Code) ──
export BASE_PACKAGES="curl git git-lfs jq xz-utils ca-certificates screen tmux openssh-client sudo python3 python3-minimal python3-pip python3-venv"

# ── Agent apt packages (full agent: compilers, dev libs, tools) ───
export AGENT_PACKAGES="make unzip xz-utils gcc g++ libc6-dev binutils pkg-config libssl-dev libcurl3t64-gnutls libicu74 libicu-dev postgresql-client shellcheck ffmpeg cmake libsdl2-dev"

# ── Playwright system deps (browser rendering libraries) ──────────
export PLAYWRIGHT_SYSTEM_DEPS="libasound2t64 libatk-bridge2.0-0t64 libatk1.0-0t64 libatspi2.0-0t64 libcairo2 libcups2t64 libdbus-1-3 libdrm2 libgbm1 libglib2.0-0t64 libnspr4 libnss3 libpango-1.0-0 libx11-6 libxcb1 libxcomposite1 libxdamage1 libxext6 libxfixes3 libxkbcommon0 libxrandr2 fonts-noto-color-emoji fonts-noto-core libfontconfig1 libfreetype6 libsqlite3-0 libavahi-client3"
